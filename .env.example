# ============================================================
# Nom - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the required values:
#   cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# Supabase (Database & Auth)
# Get these from your Supabase project: https://supabase.com/dashboard
# For local dev, run `npx supabase start` and use the output values.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------------------------
# GitHub App
# Create a GitHub App at: https://github.com/settings/apps/new
# Required permissions: Issues (read), Pull requests (read),
#   Contents (read), Metadata (read)
# Required events: push, pull_request, issues, release,
#   issue_comment, pull_request_review, pull_request_review_comment
# ------------------------------------------------------------
GITHUB_APP_ID=""
# Paste the full PEM key (including header/footer lines), or use a file path
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
# Personal access token for unauthenticated GitHub API requests (rate limiting fallback)
GITHUB_TOKEN=""

# ------------------------------------------------------------
# AI - only required for feed generation
# ------------------------------------------------------------
# OpenRouter (alternative/fallback): https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# ------------------------------------------------------------
# Web Search (Tavily) - used for enriching feed content
# https://app.tavily.com
# ------------------------------------------------------------
TAVILY_API_KEY=""

# ------------------------------------------------------------
# Email (Resend) - used for notifications
# https://resend.com
# ------------------------------------------------------------
RESEND_API_KEY=""

# ------------------------------------------------------------
# Background Jobs (Trigger.dev)
# https://cloud.trigger.dev or self-hosted
# ------------------------------------------------------------
TRIGGER_SECRET_KEY=""

# ------------------------------------------------------------
# Analytics - PostHog (optional)
# https://posthog.com
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""

# ------------------------------------------------------------
# Error Monitoring - Sentry (optional)
# https://sentry.io
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Only needed for build-time source map uploads
SENTRY_AUTH_TOKEN=""
